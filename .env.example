# ================================================================
# Kavaro Site — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ================================================================

# ── Supabase (required) ──────────────────────────────────────────
# Create a free project at https://supabase.com
# Then go to Project Settings > API to get these values.
# After changing projects, run the SQL in supabase/migrations/001_initial_schema.sql
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── Calendly (required) ──────────────────────────────────────────
# Must be a direct event URL, not just your profile page.
# e.g. https://calendly.com/your-username/30min
VITE_CALENDLY_URL=https://calendly.com/hello-kavaro/30min

# ── EmailJS (optional) ───────────────────────────────────────────
# Sends email notifications when contact form is submitted.
# Create a free account at https://emailjs.com (200 emails/month free)
# If not set, leads still save to Supabase — just no email notification.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
